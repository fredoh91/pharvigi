{% extends 'base_dark_theme.html.twig' %}

{% block title %}Modifier l'utilisateur
{% endblock %}

{% block body %}

	<div class="container my-3">
		<div class="row">
			<h1>Visualisation/Modification de l'utilisateur</h1>
			<div class="col">
				{{ form_start(form) }}

				{% include "_partials/_user_registration_edit.html.twig" %}

				<div class="row" data-controller="password-match">
					<div class="col-6">
						{{ form_label(form.plainPassword.first, 'Mot de passe :') }}
						{{ form_widget(form.plainPassword.first) }}
                        {{ form_errors(form.plainPassword.first) }}
					</div>
					<div class="col-6">
						{{ form_label(form.plainPassword.second, 'Confirmer le mot de passe :') }}
						{{ form_widget(form.plainPassword.second) }}
                        <div data-password-match-target="message"></div>
                        {{ form_errors(form.plainPassword.second) }}
					</div>
				</div>
                <div class="row mt-3">
					<div class="col-3">
						{{ form_widget(form.Valider) }}
					</div>
					<div class="col-3">
						{{ form_widget(form.Annuler) }}
					</div>
				</div>
				{# <div class="row">
								</div> #}

				{{ form_row(form._token) }}

				{# {{ form_end(form) }} #}
				{{ form_end(form, {render_rest: false}) }}
			</div>
		</div>
	</div>
{% endblock %}
